---
import BaseLayout from "../layouts/BaseLayout.astro";

const thumbnailHighlights = [
  {
    title: "Full Combo Tool Assisted Speedcore",
    src: "/images/thumbnail1.jpg",
    className: "md:col-span-8 aspect-video"
  },
  {
    title: "New Top Play!",
    src: "/images/thumbnail2.jpg",
    className: "flex-1"
  },
  {
    title: "2 Years Special",
    src: "/images/thumbnail3.jpg",
    className: "flex-1"
  },
  {
    title: "Deadly Force",
    src: "/images/thumbnail4.jpg",
    className: "md:col-span-6 aspect-video"
  },
  {
    title: "PP Rework",
    src: "/images/thumbnail5.jpg",
    className: "md:col-span-6 aspect-video"
  },
  {
    title: "1 Map 4 Gamemodes",
    src: "/images/thumbnail6.jpg",
    className: "md:col-span-6 aspect-video"
  },
  {
    title: "40 osu skins!",
    src: "/images/thumbnail7.png",
    className: "md:col-span-6 aspect-video"
  }
];

const banners = [
  "/images/banner4.jpg",
  "/images/banner2.jpg",
  "/images/banner3.png",
  "/images/banner1.jpg"
];

const brandCategories = [
  {
    id: "logos",
    label: "Logos",
    items: [
      {
        title: "Arcade Tournament Logo",
        images: ["/images/logo1.jpg", "/images/logo2.jpg"]
      }
    ]
  },
  {
    id: "campaigns",
    label: "Campaigns",
    items: [
      {
        title: "Business Campaign Design",
        images: ["/images/campaign-showcase.jpg"]
      }
    ]
  },
  {
    id: "collaterals",
    label: "Collaterals",
    items: [
      {
        title: "Public Materials",
        images: ["/images/logo3.jpg", "/images/pubmat.png"]
      }
    ]
  }
];

const reels = [
  {
    title: "Hooks to Reels",
    embed: "DX_VZrbeoHA",
  },
  {
    title: "Hooks to Reels 2",
    embed: "ldCg0SQDtJo",
  },
  {
    title: "Fast Paced",
    embed: "rRoRmOfBu9M",
  },
  {
    title: "Fast Paced and Informational",
    embed: "Cw3ayqjkRjA",
  },
  {
    title: "Trend Based",
    embed: "pSBljwLsJFM",
  },
  {
    title: "Meme Based",
    embed: "Pf3CHivMxXw",
  },
  {
    title: "Cinematic",
    embed: "UMgLdxFf5RM",
  },
  {
    title: "Informational",
    embed: "LteDBjKUeAo",
  },
  {
    title: "Teaser Reel",
    embed: "sVo2gzET6sk",
  },
  {
    title: "Call to Action",
    embed: "FPB7LHCKVng",
  }
];

const longVideos = [
  {
    title: "I Played osu! Standard after 2 Years",
    embed: "o3xgzTJgzlA"
  },
  {
    title: "The PP rework I've been waiting for",
    embed: "qgrXAWeprzc"
  },
  {
    title: "Is this $25 Magnetic Keyboard actually good for osu!?",
    embed: "js8x2QM3jPc"
  },
  {
    title: "40 osu! Skins in 2 Minutes!",
    embed: "9HXW76C0Wsc"
  }
];

const youtubeThumbnailIds = [...reels, ...longVideos].map((video) => video.embed);
const pageTitle = "Dave Cancino | Video Editor, Thumbnail Designer & Graphic Designer";
const pageDescription =
  "Portfolio of Dave Cancino showcasing video editing, YouTube thumbnails, branding, campaign design, and motion-focused creative work.";
const pageKeywords = [
  "Dave Cancino",
  "video editor",
  "graphic designer",
  "thumbnail designer",
  "YouTube video editor",
  "branding portfolio",
  "motion design"
];
const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Dave Cancino",
    jobTitle: ["Video Editor", "Graphic Designer", "Thumbnail Designer"],
    email: "mailto:cancinodavealexis@gmail.com",
    url: Astro.site?.toString(),
    sameAs: ["https://www.linkedin.com/in/davealexiscancino/"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Dave Cancino Portfolio",
    url: Astro.site?.toString(),
    description: pageDescription
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: pageTitle,
    description: pageDescription,
    url: Astro.site ? new URL("/", Astro.site).toString() : undefined,
    about: [
      "Video editing",
      "YouTube thumbnails",
      "Graphic design",
      "Branding",
      "Motion graphics"
    ]
  }
].map((entry) =>
  Object.fromEntries(Object.entries(entry).filter(([, value]) => value !== undefined))
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/thumbnail1.jpg"
  canonicalPath="/"
  keywords={pageKeywords}
  schema={pageSchema}
>
  <nav class="fixed inset-x-0 top-0 z-50 px-3 pt-3 motion-enter md:px-4 md:pt-4" data-animate>
    <div class="shell">
      <div class="relative flex min-h-20 flex-col gap-3 rounded-[1.75rem] border border-surface-line/90 bg-[#fdf8f5]/98 px-4 py-4 shadow-[0_18px_40px_-28px_rgba(34,31,28,0.45)] backdrop-blur-xl sm:min-h-20 sm:flex-row sm:items-center sm:justify-between sm:gap-4 md:rounded-[2rem] md:border md:bg-background/95 md:px-6 md:py-4 md:shadow-[0_22px_48px_-30px_rgba(34,31,28,0.38)]">
        <a href="#" class="font-display text-center text-[1.75rem] font-bold tracking-[-0.05em] text-ink sm:text-left md:text-3xl">
        Dave Cancino
        </a>

        <div class="grid w-full grid-cols-2 gap-2 sm:flex sm:w-auto sm:flex-row sm:items-center sm:justify-end sm:gap-3">
          <a
            href="mailto:cancinodavealexis@gmail.com"
            class="inline-flex min-h-[3rem] items-center justify-center rounded-full border border-surface-line bg-white px-3 py-2.5 text-center font-label text-[11px] uppercase tracking-[0.1em] text-ink shadow-[0_10px_24px_-18px_rgba(34,31,28,0.45)] transition hover:border-primary hover:text-primary sm:min-h-0 sm:w-auto sm:bg-transparent sm:px-4 sm:text-sm sm:shadow-none md:bg-white md:px-6 md:shadow-[0_12px_24px_-18px_rgba(34,31,28,0.25)]"
          >
            Get in touch
          </a>
          <a
            href="/resume.pdf"
            download="resume.pdf"
            class="inline-flex min-h-[3rem] items-center justify-center rounded-full bg-primary px-3 py-2.5 text-center font-label text-[11px] uppercase tracking-[0.1em] text-primary-ink shadow-[0_18px_32px_-20px_rgba(118,92,62,0.85)] transition hover:scale-[1.02] sm:min-h-0 sm:w-auto sm:px-4 sm:text-sm md:px-6"
          >
            Resume
          </a>
        </div>
      </div>
    </div>
  </nav>

  <header class="shell flex flex-col items-center px-5 pb-14 pt-44 text-center sm:pt-36 md:pb-24 md:pt-36">
    <h1 class="max-w-5xl font-display text-4xl leading-[0.92] tracking-[-0.04em] text-ink motion-enter sm:text-5xl md:text-7xl" data-animate style="--motion-delay: 90ms;">
      Video Editor & Graphic Designer
    </h1>

    <p class="mt-5 max-w-2xl text-base leading-7 text-ink-muted motion-enter sm:text-lg sm:leading-8 md:text-xl" data-animate style="--motion-delay: 180ms;">
      I edit videos, make thumbnails, and create graphic designs with a strong focus on energy, clarity, and constant improvement.
    </p>

    <div class="mt-7 grid w-full max-w-sm grid-cols-1 gap-3 motion-enter sm:hidden" data-animate style="--motion-delay: 260ms;">
      <a
        href="/resume.pdf"
        download="resume.pdf"
        class="inline-flex min-h-[3.25rem] items-center justify-center rounded-full bg-primary px-5 py-3 font-label text-sm uppercase tracking-[0.1em] text-primary-ink shadow-[0_22px_36px_-24px_rgba(118,92,62,0.9)] transition hover:scale-[1.02]"
      >
        Download Resume
      </a>
      <a
        href="mailto:cancinodavealexis@gmail.com"
        class="inline-flex min-h-[3.25rem] items-center justify-center rounded-full border border-surface-line bg-white px-5 py-3 font-label text-sm uppercase tracking-[0.1em] text-ink shadow-[0_16px_32px_-24px_rgba(34,31,28,0.45)] transition hover:border-primary hover:text-primary"
      >
        Email Me
      </a>
    </div>

  </header>

  <main id="work" class="shell pb-8 md:pb-10">
    <div class="mb-10 flex justify-center motion-enter md:mb-12" data-animate style="--motion-delay: 240ms;">
      <div class="flex w-full max-w-md flex-wrap justify-center rounded-[1.5rem] border border-surface-line bg-surface-muted p-1 sm:w-auto sm:flex-nowrap sm:rounded-full">
        <button id="tab-graphics" class="tab-pill tab-pill-active" type="button" data-work-target="graphics">
          Graphics
        </button>
        <button id="tab-video" class="tab-pill tab-pill-inactive" type="button" data-work-target="video">
          Video
        </button>
      </div>
    </div>

    <div id="content-graphics" data-panel="graphics">
      <section id="thumbnails" class="mb-16 md:mb-20 motion-enter" data-animate>
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="section-title text-4xl md:text-5xl">Thumbnails</h2>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
          <div class="group image-trigger card-frame lift-card relative motion-enter md:col-span-8 aspect-video" data-animate style="--motion-delay: 60ms;">
            <img src={thumbnailHighlights[0].src} alt={thumbnailHighlights[0].title} class="h-full w-full object-cover" />
            <div class="media-veil">
              <span class="mb-2 font-label text-xs uppercase tracking-[0.18em] text-primary-fog">{thumbnailHighlights[0].label}</span>
              <h3 class="font-display text-3xl text-white">{thumbnailHighlights[0].title}</h3>
            </div>
          </div>

          <div class="md:col-span-4 flex flex-col gap-6">
            {thumbnailHighlights.slice(1, 3).map((item, index) => (
              <div class="group image-trigger card-frame lift-card relative motion-enter flex-1" data-animate style={`--motion-delay: ${140 + index * 80}ms;`}>
                <img src={item.src} alt={item.title} class="h-full w-full object-cover" />
                <div class="media-veil">
                  <span class="mb-1 font-label text-xs uppercase tracking-[0.18em] text-accent">{item.label}</span>
                  <h3 class="text-xl font-semibold text-white">{item.title}</h3>
                </div>
              </div>
            ))}
          </div>

          {thumbnailHighlights.slice(3).map((item, index) => (
            <div class="group image-trigger card-frame lift-card relative aspect-video motion-enter md:col-span-6" data-animate style={`--motion-delay: ${220 + index * 70}ms;`}>
              <img src={item.src} alt={item.title} class="h-full w-full object-cover" />
              <div class="media-veil">
                <h3 class="text-xl font-semibold text-white md:text-2xl">{item.title}</h3>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="graphics" class="mb-16 md:mb-20 motion-enter" data-animate>
        <div class="mb-10 flex flex-col gap-3">
          <h2 class="section-title text-4xl md:text-5xl">Banners</h2>
        </div>

        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 z-10 hidden w-12 bg-gradient-to-r from-background to-transparent md:block"></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 z-10 hidden w-12 bg-gradient-to-l from-background to-transparent md:block"></div>
          <div
            class="flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-4 pr-4 [scrollbar-width:none] cursor-grab select-none sm:pr-8 [&::-webkit-scrollbar]:hidden active:cursor-grabbing"
            data-banner-carousel
          >
            {banners.map((banner, index) => (
              <div class="w-[min(88vw,32rem)] shrink-0 snap-start motion-enter sm:w-auto" data-animate style={`--motion-delay: ${index * 90}ms;`}>
                <button
                  type="button"
                  class="group image-trigger relative w-full rounded-2xl motion-float focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                  data-image-modal-trigger
                  data-image-src={banner}
                  data-image-alt={`Banner design ${index + 1}`}
                  aria-label={`Open banner design ${index + 1}`}
                >
                  <img src={banner} alt={`Banner design ${index + 1}`} class="pointer-events-none h-[220px] w-full object-contain sm:h-[256px] sm:w-auto sm:max-w-none" draggable="false" />
                  <div class="media-veil">
                    <h3 class="text-left text-lg font-semibold text-white md:text-xl">{`Banner design ${index + 1}`}</h3>
                  </div>
                </button>
              </div>
            ))}
          </div>
          <div class="mt-4 flex justify-center gap-2" data-banner-scroll-indicator>
            {banners.map((_, index) => (
              <button
                type="button"
                class:list={[
                  "hidden h-2 rounded-full bg-ink/20 transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background md:block",
                  index === 0 ? "w-8 bg-primary/85" : "w-2"
                ]}
                data-banner-scroll-dot
                data-banner-index={index}
                aria-label={`Go to banner design ${index + 1}`}
                aria-pressed={index === 0 ? "true" : "false"}
              ></button>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-16 md:mb-20 motion-enter" data-animate>
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <h2 class="section-title text-4xl md:text-5xl">Logos & Campaigns</h2>
          <div class="flex flex-wrap rounded-[1.5rem] border border-surface-line bg-surface-muted p-1 sm:flex-nowrap sm:rounded-full" role="tablist" aria-label="Brand work categories">
            {brandCategories.map((category, index) => (
              <button
                id={`brand-tab-${category.id}`}
                class:list={["tab-pill", index === 0 ? "tab-pill-active" : "tab-pill-inactive"]}
                type="button"
                role="tab"
                aria-controls={`brand-panel-${category.id}`}
                aria-selected={index === 0 ? "true" : "false"}
                tabindex={index === 0 ? "0" : "-1"}
                data-brand-target={category.id}
              >
                {category.label}
              </button>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          {brandCategories.map((category, index) => (
            <div
              id={`brand-panel-${category.id}`}
              role="tabpanel"
              aria-labelledby={`brand-tab-${category.id}`}
              data-brand-panel={category.id}
              class:list={["space-y-6", index === 0 ? "" : "hidden"]}
            >
              <p class="text-sm uppercase tracking-[0.12em] text-ink-muted">{category.title}</p>

              <div class="grid grid-cols-1 gap-6">
                {category.items.map((group, groupIndex) => (
                  <div class="flex flex-col gap-4 motion-enter" data-animate style={`--motion-delay: ${groupIndex * 120}ms;`}>
                    <div class="flex flex-wrap justify-center gap-4 md:justify-start">
                      {group.images.map((image, imageIndex) => (
                        <button
                          type="button"
                          class="group image-trigger relative rounded-2xl motion-enter focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                          data-animate
                          style={`--motion-delay: ${80 + imageIndex * 80}ms;`}
                          data-image-modal-trigger
                          data-image-src={image}
                          data-image-alt={`${group.title} ${group.images.length > 1 ? imageIndex + 1 : ""}`.trim()}
                          aria-label={`Open ${group.title}${group.images.length > 1 ? ` ${imageIndex + 1}` : ""}`}
                        >
                          <img src={image} alt={`${group.title} ${group.images.length > 1 ? imageIndex + 1 : ""}`.trim()} class="h-auto w-full max-w-[18rem] object-contain sm:max-w-[16rem] md:h-[256px] md:w-[256px]" />
                          <div class="media-veil">
                            <h3 class="text-left text-base font-semibold text-white md:text-lg">
                              {`${group.title}${group.images.length > 1 ? ` ${imageIndex + 1}` : ""}`}
                            </h3>
                          </div>
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div id="content-video" data-panel="video" class="hidden">
      <section class="mb-16 md:mb-20 motion-enter" data-animate>
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="section-title text-4xl md:text-5xl">Short Form Reels</h2>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
          {reels.map((reel, index) => (
            <article class="flex flex-col gap-2 motion-enter" data-animate style={`--motion-delay: ${index * 45}ms;`}>
              <p class="mt-1 text-sm font-semibold uppercase tracking-[0.08em] text-ink-soft">{reel.title}</p>
              <div class="card-frame aspect-[9/16]">
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${reel.embed}`}
                  title={reel.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="text-sm leading-6 text-ink-muted">{reel.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mb-16 md:mb-20 motion-enter" data-animate>
        <div class="mb-10">
          <h2 class="section-title text-4xl md:text-5xl">Other Videos</h2>
          <p class="mt-2 text-base text-ink-muted">Gaming and personal channel videos edited for YouTube</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {longVideos.map((video, index) => (
            <article class="flex flex-col gap-2 motion-enter" data-animate style={`--motion-delay: ${index * 90}ms;`}>
              <div class="card-frame aspect-video">
                <iframe
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${video.embed}`}
                  title={video.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="text-sm leading-6 text-ink-muted md:text-base">{video.title}</p>
            </article>
          ))}
        </div>
      </section>
    </div>

    <section id="contact" class="relative mt-16 overflow-hidden rounded-[2rem] border border-surface-line bg-surface-muted px-5 py-12 text-center motion-enter sm:px-6 md:mt-20 md:px-10 md:py-16" data-animate>
      <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(235,232,218,0.8),rgba(253,248,245,0.35))]"></div>
      <div class="relative z-10 mx-auto max-w-2xl">
        <h2 class="section-title text-4xl md:text-5xl">Ready to level up your visuals?</h2>
        <p class="mt-5 text-base leading-7 text-ink-muted sm:text-lg sm:leading-8">
          Let&apos;s collaborate on your next project, whether it&apos;s high-impact thumbnails, engaging edits, or striking graphic design.
        </p>
      </div>
    </section>
  </main>

  <footer class="border-t border-surface-line/70 bg-surface-soft">
    <div class="shell flex flex-col items-center justify-between gap-3 py-4 text-center md:flex-row md:text-left">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <p class="font-display text-lg tracking-[-0.03em] text-ink md:text-xl">Dave Cancino</p>
        <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-ink-muted md:justify-start">
          <a
            href="mailto:cancinodavealexis@gmail.com"
            class="transition hover:text-primary"
          >
            cancinodavealexis@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/davealexiscancino/"
            target="_blank"
            rel="noreferrer"
            class="transition hover:text-primary"
          >
            LinkedIn
          </a>
        </div>
      </div>
      <p class="font-label text-[11px] uppercase tracking-[0.16em] text-ink-muted">
        © 2026 All rights reserved.
      </p>
    </div>
  </footer>

  <dialog
    class="image-modal backdrop:bg-[rgba(20,18,16,0.82)] backdrop:backdrop-blur-sm"
    data-image-modal
    aria-labelledby="image-modal-caption"
  >
    <div class="image-modal__surface">
      <button
        type="button"
        class="image-modal__close"
        data-image-modal-close
        aria-label="Close image preview"
      >
        <span aria-hidden="true">×</span>
      </button>
      <figure class="image-modal__figure">
        <img class="image-modal__image" data-image-modal-content src="" alt="" />
        <figcaption id="image-modal-caption" class="image-modal__caption" data-image-modal-caption></figcaption>
      </figure>
    </div>
  </dialog>

  <script define:vars={{ youtubeThumbnailIds }}>
    const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    const animatedElements = Array.from(document.querySelectorAll("[data-animate]"));
    const workTabs = Array.from(document.querySelectorAll("[data-work-target]"));
    const workPanels = {
      graphics: document.getElementById("content-graphics"),
      video: document.getElementById("content-video")
    };
    const brandTabs = Array.from(document.querySelectorAll("[data-brand-target]"));
    const brandPanels = Object.fromEntries(
      brandTabs.map((tab) => {
        const key = tab.dataset.brandTarget ?? "";
        return [key, document.querySelector(`[data-brand-panel="${key}"]`)];
      })
    );
    const imageModal = document.querySelector("[data-image-modal]");
    const imageModalContent = imageModal?.querySelector("[data-image-modal-content]");
    const imageModalCaption = imageModal?.querySelector("[data-image-modal-caption]");
    const imageModalClose = imageModal?.querySelector("[data-image-modal-close]");
    const imageModalTriggers = Array.from(document.querySelectorAll("[data-image-modal-trigger]"));
    let thumbnailsPreloaded = false;
    let lastImageModalTrigger = null;
    let revealObserver = null;

    const animatePanel = (panel) => {
      if (!(panel instanceof HTMLElement) || motionQuery.matches) return;
      panel.classList.remove("panel-animate");
      void panel.offsetWidth;
      panel.classList.add("panel-animate");
      window.setTimeout(() => panel.classList.remove("panel-animate"), 540);
    };

    const initializeMotion = () => {
      revealObserver?.disconnect();
      revealObserver = null;

      if (motionQuery.matches) {
        document.documentElement.classList.remove("motion-ready");
        animatedElements.forEach((element) => element.classList.add("is-visible"));
        return;
      }

      document.documentElement.classList.add("motion-ready");
      revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver?.unobserve(entry.target);
            }
          });
        },
        {
          rootMargin: "0px 0px -12% 0px",
          threshold: 0.16
        }
      );

      animatedElements.forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        const isNearViewport = element.getBoundingClientRect().top <= window.innerHeight * 0.9;
        element.classList.toggle("is-visible", isNearViewport);
        if (!isNearViewport) {
          revealObserver?.observe(element);
        }
      });
    };

    const preloadYoutubeThumbnail = (videoId) => {
      const highResImage = new Image();
      highResImage.decoding = "async";
      highResImage.loading = "eager";

      highResImage.onerror = () => {
        const fallbackImage = new Image();
        fallbackImage.decoding = "async";
        fallbackImage.loading = "eager";
        fallbackImage.src = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
      };

      highResImage.src = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
    };

    const preloadYoutubeThumbnails = () => {
      if (thumbnailsPreloaded) return;
      thumbnailsPreloaded = true;

      youtubeThumbnailIds.forEach((videoId) => {
        preloadYoutubeThumbnail(videoId);
      });
    };

    const queueThumbnailPreload = () => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(() => preloadYoutubeThumbnails(), { timeout: 2000 });
        return;
      }

      window.setTimeout(preloadYoutubeThumbnails, 1200);
    };

    const updateWorkTabs = (target) => {
      workTabs.forEach((tab) => {
        const isActive = tab.dataset.workTarget === target;
        tab.classList.toggle("tab-pill-active", isActive);
        tab.classList.toggle("tab-pill-inactive", !isActive);
        tab.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      Object.entries(workPanels).forEach(([name, panel]) => {
        panel?.classList.toggle("hidden", name !== target);
        if (name === target) {
          animatePanel(panel);
        }
      });
    };

    const updateBrandTabs = (target) => {
      brandTabs.forEach((tab) => {
        const isActive = tab.dataset.brandTarget === target;
        tab.classList.toggle("tab-pill-active", isActive);
        tab.classList.toggle("tab-pill-inactive", !isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
        tab.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      Object.entries(brandPanels).forEach(([name, panel]) => {
        panel?.classList.toggle("hidden", name !== target);
        if (name === target) {
          animatePanel(panel);
        }
      });
    };

    initializeMotion();
    queueThumbnailPreload();

    workTabs.forEach((tab) => {
      const activate = () => updateWorkTabs(tab.dataset.workTarget ?? "graphics");
      tab.addEventListener("click", activate);

      if (tab.dataset.workTarget === "video") {
        tab.addEventListener("mouseenter", preloadYoutubeThumbnails, { once: true });
        tab.addEventListener("focus", preloadYoutubeThumbnails, { once: true });
      }
    });

    brandTabs.forEach((tab, index) => {
      const activate = () => updateBrandTabs(tab.dataset.brandTarget ?? "logos");
      tab.addEventListener("click", activate);
      tab.addEventListener("keydown", (event) => {
        if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;

        event.preventDefault();
        const direction = event.key === "ArrowRight" ? 1 : -1;
        const nextIndex = (index + direction + brandTabs.length) % brandTabs.length;
        const nextTab = brandTabs[nextIndex];

        nextTab?.focus();
        updateBrandTabs(nextTab?.dataset.brandTarget ?? "logos");
      });
    });

    const openImageModal = (trigger) => {
      if (!(imageModal instanceof HTMLDialogElement) || !(imageModalContent instanceof HTMLImageElement) || !(imageModalCaption instanceof HTMLElement)) {
        return;
      }

      const imageSrc = trigger.dataset.imageSrc ?? "";
      const imageAlt = trigger.dataset.imageAlt ?? "";

      imageModalContent.src = imageSrc;
      imageModalContent.alt = imageAlt;
      imageModalCaption.textContent = imageAlt;
      lastImageModalTrigger = trigger;
      imageModal.showModal();
      document.body.classList.add("modal-open");
      imageModalClose?.focus();
    };

    const closeImageModal = () => {
      if (!(imageModal instanceof HTMLDialogElement) || !imageModal.open) return;

      imageModal.close();
      document.body.classList.remove("modal-open");
      if (lastImageModalTrigger instanceof HTMLElement) {
        lastImageModalTrigger.focus();
      }
    };

    imageModalTriggers.forEach((trigger) => {
      if (!(trigger instanceof HTMLElement)) return;
      trigger.addEventListener("click", () => openImageModal(trigger));
    });

    if (imageModal instanceof HTMLDialogElement) {
      imageModal.addEventListener("click", (event) => {
        if (event.target === imageModal) {
          closeImageModal();
        }
      });

      imageModal.addEventListener("close", () => {
        document.body.classList.remove("modal-open");
      });
    }

    imageModalClose?.addEventListener("click", closeImageModal);

    const bannerCarousel = document.querySelector("[data-banner-carousel]");
    const bannerScrollIndicator = document.querySelector("[data-banner-scroll-indicator]");

    if (bannerCarousel instanceof HTMLElement) {
      const dragThreshold = 8;
      let isPointerDown = false;
      let isDragging = false;
      let activePointerId = null;
      let startX = 0;
      let startScrollLeft = 0;
      const bannerScrollDots =
        bannerScrollIndicator instanceof HTMLElement
          ? Array.from(bannerScrollIndicator.querySelectorAll("[data-banner-scroll-dot]"))
          : [];

      const updateBannerScrollIndicator = () => {
        if (!bannerScrollDots.length) return;

        const maxScrollLeft = Math.max(0, bannerCarousel.scrollWidth - bannerCarousel.clientWidth);
        const progress = maxScrollLeft <= 0 ? 0 : bannerCarousel.scrollLeft / maxScrollLeft;
        const activeIndex = Math.min(
          bannerScrollDots.length - 1,
          Math.max(0, Math.round(progress * (bannerScrollDots.length - 1)))
        );

        bannerScrollDots.forEach((dot, index) => {
          if (!(dot instanceof HTMLElement)) return;

          dot.classList.toggle("w-8", index === activeIndex);
          dot.classList.toggle("bg-primary/85", index === activeIndex);
          dot.classList.toggle("w-2", index !== activeIndex);
          dot.classList.toggle("bg-ink/20", index !== activeIndex);
          dot.setAttribute("aria-pressed", index === activeIndex ? "true" : "false");
        });

        if (bannerScrollIndicator instanceof HTMLElement) {
          bannerScrollIndicator.classList.toggle("opacity-0", maxScrollLeft <= 16);
        }
      };

      const startDragging = (clientX, pointerId) => {
        isPointerDown = true;
        isDragging = false;
        activePointerId = pointerId;
        startX = clientX;
        startScrollLeft = bannerCarousel.scrollLeft;
      };

      const dragTo = (clientX, pointerId) => {
        if (activePointerId !== pointerId) return;
        if (!isPointerDown) return;
        const deltaX = clientX - startX;

        if (!isDragging && Math.abs(deltaX) >= dragThreshold) {
          isDragging = true;
        }

        if (!isDragging) return;
        bannerCarousel.scrollLeft = startScrollLeft - deltaX;
      };

      const stopDragging = (pointerId) => {
        if (activePointerId !== pointerId) return;
        if (!isPointerDown) return;
        isPointerDown = false;
        isDragging = false;
        activePointerId = null;
      };

      bannerCarousel.addEventListener("pointerdown", (event) => {
        if (event.pointerType === "mouse" && event.button !== 0) return;
        startDragging(event.clientX, event.pointerId);
      });

      bannerCarousel.addEventListener("pointermove", (event) => {
        dragTo(event.clientX, event.pointerId);
      });

      bannerCarousel.addEventListener("pointerup", (event) => {
        stopDragging(event.pointerId);
      });

      bannerCarousel.addEventListener("scroll", () => {
        updateBannerScrollIndicator();
      }, { passive: true });

      bannerCarousel.addEventListener("pointercancel", (event) => {
        stopDragging(event.pointerId);
      });

      bannerCarousel.addEventListener("pointerleave", (event) => {
        if (event.pointerType === "mouse") {
          stopDragging(event.pointerId);
        }
      });

      bannerScrollDots.forEach((dot) => {
        if (!(dot instanceof HTMLButtonElement)) return;

        dot.addEventListener("click", () => {
          const targetIndex = Number(dot.dataset.bannerIndex ?? "0");
          const slides = Array.from(bannerCarousel.children);
          const targetSlide = slides[targetIndex];

          if (!(targetSlide instanceof HTMLElement)) return;

          bannerCarousel.scrollTo({
            left: targetSlide.offsetLeft,
            behavior: "smooth"
          });
        });
      });

      updateBannerScrollIndicator();
      window.addEventListener("resize", updateBannerScrollIndicator, { passive: true });
    }

    motionQuery.addEventListener("change", initializeMotion);

  </script>
</BaseLayout>
